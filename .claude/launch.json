{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "serve (static)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "projeta-landing", "--listen", "3000"],
      "port": 3000
    },
    {
      "name": "live-server (hot reload)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["live-server", "projeta-landing", "--port=3001", "--no-browser"],
      "port": 3001
    }
  ]
}
